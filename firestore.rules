rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorizedUser() {
      return isSignedIn()
        && request.auth.token.email in [
          "elvishp2006@gmail.com",
          "regianegoncalvesm@gmail.com",
          "pedropaulohenriques29@gmail.com",
          "churrascariadogaucho.petisco@gmail.com"
        ];
    }

    function hasOnlyKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function isNullableInt(value) {
      return value == null || value is int;
    }

    function isNullableBool(value) {
      return value == null || value is bool;
    }

    function isValidSelectionPolicy(policy) {
      return policy is map
        && policy.keys().hasOnly([
          'minSelections',
          'maxSelections',
          'sharedLimitGroupId',
          'allowRepeatedItems'
        ])
        && isNullableInt(policy.minSelections)
        && isNullableInt(policy.maxSelections)
        && isNullableString(policy.sharedLimitGroupId)
        && policy.allowRepeatedItems is bool;
    }

    function isValidCatalogCategory(categoryId) {
      return request.resource.data.keys().hasOnly([
          'name',
          'sortOrder',
          'selectionPolicy'
        ])
        && categoryId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.sortOrder is int
        && isValidSelectionPolicy(request.resource.data.selectionPolicy);
    }

    function isValidCatalogItem() {
      return request.resource.data.keys().hasOnly([
          'categoryId',
          'name',
          'priceCents',
          'isActive',
          'alwaysActive',
          'sortOrder'
        ])
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.priceCents is int
        && request.resource.data.priceCents >= 0
        && request.resource.data.isActive is bool
        && request.resource.data.alwaysActive is bool
        && request.resource.data.sortOrder is int;
    }

    function isValidDailyMenu(dateKey) {
      return request.resource.data.keys().hasOnly([
          'dateKey',
          'status',
          'shareToken',
          'activeVersionId',
          'itemIds',
          'updatedAt'
        ])
        && request.resource.data.dateKey == dateKey
        && request.resource.data.status in ['draft', 'published', 'closed']
        && isNullableString(request.resource.data.shareToken)
        && isNullableString(request.resource.data.activeVersionId)
        && request.resource.data.itemIds is list
        && request.resource.data.updatedAt is int
        && (
          request.resource.data.status == 'draft'
          || (
            request.resource.data.shareToken is string
            && request.resource.data.activeVersionId is string
          )
        );
    }

    function isValidPublishedMenuVersion(dateKey, versionId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'dateKey',
          'shareToken',
          'createdAt',
          'categories',
          'items'
        ])
        && request.resource.data.id == versionId
        && request.resource.data.dateKey == dateKey
        && request.resource.data.shareToken is string
        && request.resource.data.createdAt is int
        && request.resource.data.categories is list
        && request.resource.data.items is list;
    }

    function isValidDailyMenuToken(shareToken) {
      return request.resource.data.keys().hasOnly([
          'shareToken',
          'dateKey',
          'activeVersionId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.shareToken == shareToken
        && request.resource.data.dateKey is string
        && request.resource.data.activeVersionId is string
        && request.resource.data.createdAt is int
        && request.resource.data.updatedAt is int;
    }

    function isValidPaymentSummary(summary) {
      return summary is map
        && summary.keys().hasOnly([
          'freeTotalCents',
          'paidTotalCents',
          'currency',
          'paymentStatus',
          'provider',
          'paymentMethod',
          'providerPaymentId',
          'refundedAt'
        ])
        && summary.freeTotalCents is int
        && summary.paidTotalCents is int
        && summary.currency == 'BRL'
        && summary.paymentStatus is string
        && isNullableString(summary.provider)
        && isNullableString(summary.paymentMethod)
        && isNullableString(summary.providerPaymentId)
        && isNullableInt(summary.refundedAt);
    }

    function isValidOrder(dateKey, orderId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'dateKey',
          'shareToken',
          'menuVersionId',
          'customerName',
          'observation',
          'lines',
          'paymentSummary',
          'submittedAt',
          'sourceDraftId'
        ])
        && request.resource.data.id == orderId
        && request.resource.data.dateKey == dateKey
        && request.resource.data.shareToken is string
        && request.resource.data.menuVersionId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && (!('observation' in request.resource.data) || isNullableString(request.resource.data.observation))
        && request.resource.data.lines is list
        && request.resource.data.lines.size() > 0
        && isValidPaymentSummary(request.resource.data.paymentSummary)
        && request.resource.data.submittedAt is int
        && isNullableString(request.resource.data.sourceDraftId);
    }

    function isValidPublicOrderDraft(draftId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'dateKey',
          'shareToken',
          'orderId',
          'customerName',
          'menuVersionId',
          'selectedItems',
          'paymentSummary',
          'checkoutSession',
          'failureReason',
          'supersededByDraftId',
          'supersededAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == draftId
        && request.resource.data.dateKey is string
        && request.resource.data.shareToken is string
        && request.resource.data.orderId is string
        && request.resource.data.customerName is string
        && request.resource.data.menuVersionId is string
        && request.resource.data.selectedItems is list
        && isValidPaymentSummary(request.resource.data.paymentSummary)
        && (request.resource.data.checkoutSession == null || request.resource.data.checkoutSession is map)
        && isNullableString(request.resource.data.failureReason)
        && isNullableString(request.resource.data.supersededByDraftId)
        && isNullableInt(request.resource.data.supersededAt)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidEditorLock() {
      return request.resource.data.keys().hasOnly([
          'sessionId',
          'userEmail',
          'deviceLabel',
          'status',
          'acquiredAt',
          'lastHeartbeatAt',
          'expiresAt'
        ])
        && request.resource.data.sessionId is string
        && request.resource.data.userEmail is string
        && request.resource.data.deviceLabel is string
        && request.resource.data.status == 'active'
        && request.resource.data.acquiredAt is int
        && request.resource.data.lastHeartbeatAt is int
        && request.resource.data.expiresAt is int;
    }

    function isPublicDailyMenuReadable() {
      return resource.data.status in ['published', 'closed']
        && resource.data.shareToken is string
        && resource.data.activeVersionId is string
        && resource.data.itemIds is list
        && resource.data.updatedAt is int;
    }

    match /catalog/root/categories/{categoryId} {
      allow read: if isAuthorizedUser();
      allow create, update: if isAuthorizedUser() && isValidCatalogCategory(categoryId);
      allow delete: if isAuthorizedUser();
    }

    match /catalog/root/items/{itemId} {
      allow read: if isAuthorizedUser();
      allow create, update: if isAuthorizedUser() && isValidCatalogItem();
      allow delete: if isAuthorizedUser();
    }

    match /config/editorLock {
      allow read: if isAuthorizedUser();
      allow create, update: if isAuthorizedUser() && isValidEditorLock();
      allow delete: if isAuthorizedUser();
    }

    match /dailyMenus/{dateKey} {
      allow get, list: if isAuthorizedUser() || isPublicDailyMenuReadable();
      allow create, update: if isAuthorizedUser() && isValidDailyMenu(dateKey);
      allow delete: if false;
    }

    match /dailyMenus/{dateKey}/versions/{versionId} {
      allow get, list: if isAuthorizedUser()
        || (
          exists(/databases/$(database)/documents/dailyMenus/$(dateKey))
          && get(/databases/$(database)/documents/dailyMenus/$(dateKey)).data.activeVersionId == versionId
          && get(/databases/$(database)/documents/dailyMenus/$(dateKey)).data.status in ['published', 'closed']
        );
      allow create: if isAuthorizedUser() && isValidPublishedMenuVersion(dateKey, versionId);
      allow update, delete: if false;
    }

    match /dailyMenuTokens/{shareToken} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isAuthorizedUser() && isValidDailyMenuToken(shareToken);
      allow delete: if false;
    }

    match /dailyMenus/{dateKey}/orders/{orderId} {
      allow read: if isAuthorizedUser();
      allow create, update, delete: if false;
    }

    match /publicOrderDrafts/{draftId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
