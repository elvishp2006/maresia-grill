{
  "name": "menu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "emulators": "npm --prefix functions run build && firebase emulators:start",
    "dev:local": "concurrently -n emulators,vite -c cyan,green \"npm run emulators\" \"npm run dev\"",
    "stripe:test:seed": "node scripts/seed-stripe-test.js",
    "stripe:test:app": "vite --host 127.0.0.1 --port 5173",
    "stripe:test:emulators": "npm --prefix functions run build && firebase emulators:start --config firebase.stripe.json --only auth,firestore,functions --project menu-7f7cd",
    "stripe:test:dev": "concurrently -n emulators,vite -c cyan,green \"npm run stripe:test:emulators\" \"npm run stripe:test:app\"",
    "stripe:test:webhook": "stripe listen --forward-to http://127.0.0.1:5001/menu-7f7cd/us-central1/paymentWebhook",
    "gcp:bootstrap": "bash scripts/bootstrap-gcp.sh",
    "gcp:check": "bash scripts/check-gcp-deploy.sh",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run test && npm run build",
    "prepare": "husky",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.10.0",
    "firebase": "^12.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.7.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
